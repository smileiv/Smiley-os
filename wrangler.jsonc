{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "smiley-proxy",
  "compatibility_date": "2026-05-22",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
[vars]
# Other vars...

[[kv_namespaces]]
binding = "CONCIERGE_TICKETS"
id = "<YOUR_KV_ID>"
